pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/nssnprasad-alt/playwright.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Install Browsers') {
            steps {
                bat 'npx playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                script {

                    def status = bat(
                        script: 'npx playwright test',
                        returnStatus: true
                    )

                    echo "First Run Exit Code : ${status}"

                    if(status != 0){
                        currentBuild.result = 'UNSTABLE'
                    }
                }
            }
        }

        stage('Rerun Failed Tests') {
            when {
                expression {
                    currentBuild.result == 'UNSTABLE'
                }
            }

            steps {
                script {

                    echo "Re-running failed test cases..."

                    def rerun = bat(
                        script: 'npx playwright test --last-failed',
                        returnStatus: true
                    )

                    echo "Rerun Exit Code : ${rerun}"

                    if(rerun == 0){
                        echo "All failed tests passed after rerun."
                        currentBuild.result = 'SUCCESS'
                    }else{
                        echo "Some tests are still failing."
                        currentBuild.result = 'UNSTABLE'
                    }
                }
            }
        }
    }

    post {

        always {

            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright Report'
            ])

            archiveArtifacts artifacts: 'playwright-report/**', fingerprint: true

            echo 'Pipeline Finished'
        }

        success {
            echo 'Pipeline Passed Successfully'
        }

        unstable {
            echo 'Some test cases failed. Check the HTML Report.'
        }

        failure {
            echo 'Pipeline Failed'
        }
    }
}